    "imageEdit": {"type": "object", "additionalProperties": false, "required": ["instruction", "sources"], "properties": {"instruction": {"type": "string", "minLength": 1}, "sources": {"$ref": "#/$defs/mediaInputArray"}, "count": {"$ref": "#/$defs/positiveInteger"}, "width": {"$ref": "#/$defs/positiveInteger"}, "height": {"$ref": "#/$defs/positiveInteger"}, "aspect_ratio": {"type": "string"}, "resolution": {"type": "string"}, "quality": {"type": "string"}, "output_format": {"type": "string"}}},
    "videoGenerate": {"type": "object", "additionalProperties": false, "required": ["prompt"], "properties": {"prompt": {"type": "string", "minLength": 1}, "negative_prompt": {"type": "string"}, "inputs": {"type": "array", "items": {"$ref": "#/$defs/mediaInput"}}, "duration_seconds": {"$ref": "#/$defs/positiveNumber"}, "width": {"$ref": "#/$defs/positiveInteger"}, "height": {"$ref": "#/$defs/positiveInteger"}, "resolution": {"type": "string"}, "aspect_ratio": {"type": "string"}, "frames_per_second": {"$ref": "#/$defs/positiveNumber"}, "output_format": {"type": "string"}, "seed": {"type": "integer"}, "count": {"$ref": "#/$defs/positiveInteger"}, "watermark": {"type": "boolean"}, "prompt_extend": {"type": "boolean"}}},
    "videoEdit": {"type": "object", "additionalProperties": false, "required": ["instruction", "source"], "properties": {"instruction": {"type": "string", "minLength": 1}, "source": {"$ref": "#/$defs/mediaInput"}, "references": {"type": "array", "items": {"$ref": "#/$defs/mediaInput"}}}},
    "videoExtend": {"type": "object", "additionalProperties": false, "required": ["source", "additional_duration_seconds"], "properties": {"source": {"$ref": "#/$defs/mediaInput"}, "prompt": {"type": "string"}, "additional_duration_seconds": {"$ref": "#/$defs/positiveNumber"}}},
    "speechSegment": {"type": "object", "additionalProperties": false, "required": ["text", "voice_id"], "properties": {"text": {"type": "string", "minLength": 1}, "voice_id": {"type": "string", "minLength": 1}}},
    "speechSynthesize": {"type": "object", "additionalProperties": false, "required": ["text", "voice_id"], "properties": {"text": {"type": "string", "minLength": 1}, "segments": {"type": "array", "items": {"$ref": "#/$defs/speechSegment"}}, "voice_id": {"type": "string", "minLength": 1}, "language": {"type": "string"}, "style": {"type": "string"}, "speed": {"$ref": "#/$defs/positiveNumber"}, "pitch": {"$ref": "#/$defs/positiveNumber"}, "volume": {"$ref": "#/$defs/positiveNumber"}, "output_format": {"type": "string"}, "sample_rate": {"$ref": "#/$defs/positiveInteger"}, "bitrate": {"$ref": "#/$defs/positiveInteger"}, "channels": {"$ref": "#/$defs/positiveInteger"}, "timestamps": {"type": "boolean"}, "pronunciations": {"$ref": "#/$defs/stringArray"}}},
    "speechTranscribe": {"type": "object", "additionalProperties": false, "required": ["source"], "properties": {"source": {"$ref": "#/$defs/mediaInput"}, "language": {"type": "string"}, "translation_target": {"type": "string"}, "prompt": {"type": "string"}, "hotwords": {"$ref": "#/$defs/stringArray"}, "diarization": {"type": "boolean"}, "segment_timestamps": {"type": "boolean"}, "word_timestamps": {"type": "boolean"}, "candidate_count": {"$ref": "#/$defs/positiveInteger"}}},
    "embeddingInput": {"type": "object", "additionalProperties": false, "required": ["id"], "properties": {"id": {"type": "string", "minLength": 1}, "text": {"type": "string"}, "resource": {"$ref": "#/$defs/resourceReference"}}, "oneOf": [{"required": ["text"]}, {"required": ["resource"]}]},
    "embeddingCreate": {"type": "object", "additionalProperties": false, "required": ["inputs", "input_task", "output_kind", "encoding"], "properties": {"inputs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/embeddingInput"}}, "input_task": {"enum": ["provider_default", "query", "document", "semantic_similarity", "classification", "clustering", "code_retrieval"]}, "dimensions": {"$ref": "#/$defs/positiveInteger"}, "output_kind": {"enum": ["dense", "sparse", "multi_vector"]}, "encoding": {"enum": ["float", "base64"]}}},
    "rerankContent": {"type": "object", "additionalProperties": false, "properties": {"text": {"type": "string"}, "resource": {"$ref": "#/$defs/resourceReference"}}, "oneOf": [{"required": ["text"]}, {"required": ["resource"]}]},
