", "additionalProperties": false, "required": ["tool_call_id"], "properties": {"tool_call_id": {"type": "string"}, "computer_screenshot": {"$ref": "#/$defs/computerScreenshot"}}}, "reasoning": {"type": "object", "additionalProperties": false, "properties": {"summary": {"type": "boolean"}, "continuation_ref": {"type": "string"}}}, "refusal": {"type": "object", "additionalProperties": false, "properties": {"reason_code": {"type": "string"}}}}},
    "toolDefinition": {"type": "object", "additionalProperties": false, "required": ["kind", "name"], "properties": {"kind": {"enum": ["function", "custom", "native_web_search", "provider_file_search", "provider_code_interpreter", "provider_computer_use"]}, "namespace": {"type": "string"}, "name": {"type": "string", "minLength": 1}, "description": {"type": "string"}, "parameters": {}, "strict": {"type": "boolean"}, "file_search": {"type": "object", "additionalProperties": false, "required": ["store_ids"], "properties": {"store_ids": {"$ref": "#/$defs/stringArray"}, "max_results": {"$ref": "#/$defs/positiveInteger"}}}, "code_interpreter": {"type": "object", "additionalProperties": false, "properties": {"container_id": {"type": "string"}, "memory_limit": {"enum": ["1g", "4g", "16g", "64g"]}}, "not": {"required": ["container_id", "memory_limit"]}}, "computer_use": {"type": "object", "additionalProperties": false, "properties": {"mode": {"enum": ["ga", "preview"]}, "environment": {"enum": ["browser", "linux", "windows", "macos"]}, "display_width": {"$ref": "#/$defs/positiveInteger"}, "display_height": {"$ref": "#/$defs/positiveInteger"}}, "oneOf": [{"required": ["mode"], "properties": {"mode": {"const": "ga"}}, "not": {"anyOf": [{"required": ["environment"]}, {"required": ["display_width"]}, {"required": ["display_height"]}]}}, {"required": ["mode", "environment", "display_width", "display_height"], "properties": {"mode": {"const": "preview"}}}]}}},
