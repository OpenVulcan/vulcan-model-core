    "rerankQuery": {"type": "object", "additionalProperties": false, "required": ["id", "content"], "properties": {"id": {"type": "string", "minLength": 1}, "content": {"$ref": "#/$defs/rerankContent"}}},
    "rerankDocuments": {"type": "object", "additionalProperties": false, "required": ["query", "candidates", "truncation"], "properties": {"query": {"$ref": "#/$defs/rerankQuery"}, "candidates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/rerankCandidate"}}, "top_n": {"$ref": "#/$defs/positiveInteger"}, "return_content": {"type": "boolean"}, "truncation": {"enum": ["none", "provider"]}}},
    "searchWeb": {"type": "object", "additionalProperties": false, "required": ["query", "domains", "time", "locale", "location", "safe_search", "output_mode", "evidence_requirement"], "properties": {"query": {"type": "string", "minLength": 1}, "domains": {"type": "object", "additionalProperties": false, "properties": {"allow": {"$ref": "#/$defs/stringArray"}, "block": {"$ref": "#/$defs/stringArray"}}}, "time": {"type": "object", "additionalProperties": false, "properties": {"published_after": {"type": "string", "format": "date-time"}, "published_before": {"type": "string", "format": "date-time"}}}, "locale": {"type": "object", "additionalProperties": false, "properties": {"language": {"type": "string"}, "region": {"type": "string"}}}, "location": {"type": "object", "additionalProperties": false, "properties": {"country": {"type": "string"}, "region": {"type": "string"}, "city": {"type": "string"}, "timezone": {"type": "string"}}}, "safe_search": {"enum": ["off", "moderate", "strict"]}, "max_results": {"$ref": "#/$defs/positiveInteger"}, "output_mode": {"enum": ["results", "answer_with_citations", "results_and_answer"]}, "evidence_requirement": {"enum": ["best_effort", "verified"]}}},
