ired": ["path"]}]}}, {"properties": {"type": {"enum": ["wait", "screenshot"]}}, "not": {"anyOf": [{"required": ["x"]}, {"required": ["y"]}, {"required": ["button"]}, {"required": ["scroll_x"]}, {"required": ["scroll_y"]}, {"required": ["text"]}, {"required": ["keys"]}, {"required": ["path"]}]}}]},
    "computerScreenshot": {"type": "object", "additionalProperties": false, "required": ["resource_ref", "detail"], "properties": {"resource_ref": {"type": "string", "minLength": 1}, "detail": {"const": "original"}}},
