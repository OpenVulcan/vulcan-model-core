{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openvulcan.dev/vcp/1.0/execution-record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "status", "operation", "created_at", "updated_at", "expires_at", "revision"],
  "properties": {
    "id": {"type": "string", "pattern": "^exe_[0-9a-f]{32}$"},
    "status": {"enum": ["accepted", "preparing_inputs", "queued", "running", "waiting_retry", "succeeded", "partially_succeeded", "failed", "cancelled", "expired"]},
    "operation": {"enum": ["conversation.respond", "media.analyze", "image.generate", "image.edit", "video.generate", "video.edit", "video.extend", "speech.synthesize", "speech.transcribe", "embedding.create", "rerank.documents", "search.web", "music.generate", "music.cover.prepare", "music.cover"]},
    "result": {"$ref": "./execution-result.schema.json"},
    "failure": {"$ref": "./failure.schema.json"},
    "retry": {"$ref": "./retry-state.schema.json"},
    "retry_cycles": {"type": "integer", "minimum": 0},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "revision": {"type": "integer", "minimum": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"enum": ["succeeded", "partially_succeeded"]}}, "required": ["status"]},
      "then": {"required": ["result"]},
      "else": {"not": {"required": ["result"]}}
    },
    {
      "if": {"properties": {"status": {"const": "failed"}}, "required": ["status"]},
      "then": {"required": ["failure"]},
      "else": {"not": {"required": ["failure"]}}
    },
    {
      "if": {"properties": {"status": {"const": "waiting_retry"}}, "required": ["status"]},
      "then": {"required": ["retry"]},
      "else": {"not": {"required": ["retry"]}}
    }
  ]
}
