{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openvulcan.dev/vcp/1.0/input-plan-request.schema.json",
  "title": "VCP Input Plan Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["model", "operation", "inputs"],
  "properties": {
    "model": {"type": "object", "additionalProperties": false, "required": ["target", "provider_instance_id", "provider_model_id", "execution_profile_id"], "properties": {"target": {"const": "exact"}, "provider_instance_id": {"type": "string"}, "provider_model_id": {"type": "string"}, "execution_profile_id": {"type": "string"}}},
    "operation": {"enum": ["conversation.respond", "media.analyze", "image.generate", "image.edit", "video.generate", "video.edit", "video.extend", "speech.synthesize", "speech.transcribe", "embedding.create", "rerank.documents", "search.web", "web.extract", "music.generate", "music.cover.prepare", "music.cover"]},
    "inputs": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "required_features": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "allow_projection": {"type": "boolean"}
  }
}
